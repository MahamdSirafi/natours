extends base

block content
    main.main
        .auth-form
            h2.heading-secondary.ma-bt-lg Add a New Tour
            form.form-add-tour
                .form__group
                    label.form__label(for='name') Tour Name
                    input#name.form__input(type='text', name='name', placeholder='Tour name')
                .form__group
                    label.form__label(for='duration') Duration (days)
                    input#duration.form__input(type='number', name='duration', placeholder='Number of days')
                .form__group
                    label.form__label(for='maxGroupSize') Max Group Size
                    input#maxGroupSize.form__input(type='number', name='maxGroupSize', placeholder='Max group size')
                .form__group
                    label.form__label(for='difficulty') Difficulty
                    select#difficulty.form__input(name='difficulty')
                        option(value='easy') Easy
                        option(value='medium') Medium
                        option(value='difficult') Difficult
                .form__group
                    label.form__label(for='price') Price
                    input#price.form__input(type='number', name='price', placeholder='Price in USD')
                .form__group
                    label.form__label(for='priceDiscount') Discount Price (optional)
                    input#priceDiscount.form__input(type='number', name='priceDiscount', placeholder='Discount price in USD')
                .form__group
                    label.form__label(for='summary') Summary
                    textarea#summary.form__input(name='summary', placeholder='Short description of the tour')
                .form__group
                    label.form__label(for='description') Detailed Description
                    textarea#description.form__input(name='description', placeholder='Detailed description of the tour')
                .form__group
                    label.form__label(for="imageCover") Cover Image
                    input#imageCover.form__input(type="file", name="imageCover", accept='image/*')
                .form__group
                    label.form__label(for="image1") Image 1
                    input#image1.form__input(type="file", name="image1", accept='image/*')
                .form__group
                    label.form__label(for="image2") Image 2
                    input#image2.form__input(type="file", name="image2", accept='image/*')
                .form__group
                    label.form__label(for="image3") Image 3
                    input#image3.form__input(type="file", name="image3", accept='image/*')
                .form__group
                    label.form__label(for='startDates') Start Dates (comma separated)
                    input#startDates.form__input(type='text', name='startDates', placeholder='Comma separated start dates (e.g., YYYY-MM-DD)')
                .form__group
                    label.form__label Tour Guides
                    #selected-guides
                    #guide-select-wrapper(style='display:none')
                        select#guide-selector.form__input
                            option(value='') -- Select a guide --
                    button#add-guide-btn.btn.btn--small.btn--green(type='button') + Add Guide
                    input#guides-data(type='hidden', name='guides', value='[]')
                input#startLocationCoordinates(type='hidden', name='startLocationCoordinates')
                .form__group
                    label.form__label Tour Locations
                    #locations-list.locations-list
                    #location-form-wrapper(style='display:none')
                        .location-form
                            p(style='font-size:1.3rem;color:#55c57a;margin-bottom:1rem;') Click on the map to pick coordinates, then fill the details
                            .form__group
                                label.form__label(for='loc-desc') Description
                                input#loc-desc.form__input(type='text', placeholder='e.g. Scenic viewpoint')
                            .form__group
                                label.form__label(for='loc-day') Day
                                input#loc-day.form__input(type='number', min='1', value='1')
                            .form__group
                                label.form__label Coordinates
                                div(style='display:flex;gap:1rem;')
                                    input#loc-lng.form__input(type='text', placeholder='Longitude', readonly, style='background:#f7f7f7;flex:1;')
                                    input#loc-lat.form__input(type='text', placeholder='Latitude', readonly, style='background:#f7f7f7;flex:1;')
                            div(style='display:flex;gap:0.5rem;margin-top:0.5rem;')
                                button#location-save.btn.btn--green.btn--small(type='button') Save Location
                                button#location-cancel.btn.btn--black.btn--small(type='button') Cancel
                    #map-container(style='height: 400px;')
                    p#map-instruction(style='display:none;color:#55c57a;font-size:1.3rem;margin-top:0.5rem;') Click on the map to place a location
                    button#add-location-btn.btn.btn--small.btn--green(type='button') + Add Location
                    input#locations-data(type='hidden', name='locations', value='[]')
                .form__group.sign
                    button.btn.btn--green(type='submit') Add Tour
                    button.btn.btn--black(type='reset') Reset
