{
  "name": "natours",
  "version": "1.0.0",
  "description": "learning node, express and mongoDB",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node index.js",
    "seed:add": "node ./dev-data/data/import-dev-data.js --import",
    "seed:delete": "node ./dev-data/data/import-dev-data.js --delete",
    "start:dev": "nodemon server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "watch:js": "esbuild ./public/js/index.js --bundle --outfile=./public/bundle.js --target=es2015 --format=iife --global-name=Natours --watch",
    "build:js": "esbuild ./public/js/index.js --bundle --outfile=./public/bundle.js --target=es2015 --format=iife --global-name=Natours"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahamdSirafi/natours.git"
  },
  "author": "Mohammed Adel Seirafi",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MahamdSirafi/natours/issues"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "axios": "^1.3.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.0.1",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.4",
    "jsonwebtoken": "^9.0.0",
    "mapbox-gl": "^2.13.0",
    "mongoose": "^6.7.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.8.0",
    "nodemon": "^2.0.20",
    "pug": "^3.0.2",
    "sharp": "^0.33.4",
    "slugify": "^1.6.5",
    "stripe": "^11.14.0",
    "util": "^0.12.5",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/morgan": "^1.9.3",
    "esbuild": "^0.28.0",
    "eslint": "^8.34.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
